FROM node:22
WORKDIR /app

# Copy root package files
COPY package.json package-lock.json* ./

# Copy all workspace package.json files to allow npm to see the full graph
# This is crucial for monorepo dependency resolution
COPY apps/buyer/package.json ./apps/buyer/
COPY apps/seller/package.json ./apps/seller/
COPY apps/admin/package.json ./apps/admin/
COPY packages/api/package.json ./packages/api/
COPY packages/ui/package.json ./packages/ui/
COPY packages/config/package.json ./packages/config/

# Install all dependencies for the entire workspace
RUN npm install

# Copy the rest of the source code
COPY . .

# Move to the specific app directory
WORKDIR /app/apps/buyer
EXPOSE 3000
# Ensure we use --host to allow external access
CMD ["npm", "run", "dev", "--", "--host"]
