{
    local_certs
}

localhost {
    log {
        output stdout
    }

    # Keycloak Auth (Preserve /auth prefix)
    handle /auth* {
        reverse_proxy keycloak:8080
    }

    # Backend API (Preserve /api prefix)
    handle /api* {
        reverse_proxy backend:8080
    }

    # Frontend (Everything else)
    handle {
        reverse_proxy frontend:3000
    }
}
